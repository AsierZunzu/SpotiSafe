# Required: your Spotify application's client ID
SPOTIFY_CLIENT_ID=your_client_id_here

# Optional: client secret (not required for PKCE flow)
SPOTIFY_CLIENT_SECRET=

# OAuth redirect URI — must match what you registered in Spotify Developer Dashboard
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# Port for the local OAuth callback server
SPOTIFY_CALLBACK_PORT=8888

# Directory where backup JSON files are written
SPOTIFY_OUTPUT_DIR=./output

# Path to the persisted token file (allows skipping browser auth on re-runs)
SPOTIFY_TOKEN_FILE=./output/.spotify_token.json

# Cron schedule for recurring backups (e.g. "0 2 * * *" for 2 AM daily).
# Leave unset to run once and exit.
SPOTIFY_SCHEDULE=

# Set to "true" to skip the immediate backup run at startup when a schedule is set.
SPOTIFY_SKIP_INITIAL_RUN=false

# Log level: debug, info, warn, error
LOG_LEVEL=info
